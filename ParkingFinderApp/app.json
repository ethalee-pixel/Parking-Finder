{
  "expo": {
    "name": "ParkingFinderApp",
    "slug": "ParkingFinderApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kylep1.ParkingFinderApp",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "ParkingFinder uses your location to center the map, validate nearby spot reports, and help you report parking accurately.",
        "NSUserNotificationsUsageDescription": "ParkingFinder sends notifications when your reported spot is close to expiring.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "icon": "./assets/icon.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFD600"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "config": {
        "googleMaps": {
          "apiKey": "REPLACE_WITH_ANDROID_GOOGLE_MAPS_API_KEY"
        }
      },
      "package": "com.kylep1.ParkingFinderApp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "9293b386-1409-4d2e-af4e-1caff359c85a"
      }
    }
  }
}
