{
  "cli": {
    "appVersionSource": "remote"
  },
  "build": {
    "preview-apk": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      }
    },
    "preview-ios": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      }
    },
    "production-ios": {
      "autoIncrement": true,
      "ios": {
        "simulator": false
      }
    }
  }
}
